          2 | Apollo 12 | 11-14-1969  | 11-24-1969 |             1 | NASA   | Lunar Landing | Success         |          25400.00 |            10
         11 | Apollo 13 | 04-11-1970  | 04-17-1970 |             1 | NASA   | Lunar Landing | Partial Failure |          25400.00 |             6
         18 | Apollo 17 | 12-07-1972  | 12-19-1972 |             1 | NASA   | Lunar Landing | Success         |          25400.00 |            12
         17 | Apollo 8  | 12-21-1968  | 12-25-1968 |             1 | NASA   | Lunar Orbit   | Success         |          25400.00 |             4
(5 rows)

-- Aggregation
SELECT count(*) FROM frozen_missions;
 count 
-------
    68
(1 row)

-- READ-ONLY enforcement
INSERT INTO frozen_missions VALUES (1, 'test');
ERROR:  ducklake_fdw tables are read-only
HINT:  INSERT is not supported on foreign tables created with ducklake_fdw.
UPDATE frozen_missions SET name = 'test' WHERE mission_id = 1;
ERROR:  ducklake_fdw tables are read-only
HINT:  UPDATE is not supported on foreign tables created with ducklake_fdw.
DELETE FROM frozen_missions WHERE mission_id = 1;
ERROR:  ducklake_fdw tables are read-only
HINT:  DELETE is not supported on foreign tables created with ducklake_fdw.
-- Error: non-existent table in frozen ducklake
CREATE FOREIGN TABLE frozen_nonexistent ()
    SERVER frozen_space
    OPTIONS (schema_name 'main', table_name 'no_such_table');
ERROR:  ducklake_fdw: column inference ATTACH failed: Binder Error: Failed to attach DuckLake MetaData "__ducklake_metadata___ducklake_fdw_probe__" at path + "/tmp/pg_ducklake_testdata/space.ducklake"Unique file handle conflict: Cannot attach "__ducklake_metadata___ducklake_fdw_probe__" - the database file "/private/tmp/pg_ducklake_testdata/space.ducklake" is already attached by database "__ducklake_metadata_frozen_space"
-- Cleanup
DROP FOREIGN TABLE frozen_missions;
DROP SERVER frozen_space;
