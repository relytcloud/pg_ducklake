-- Test access control for DuckLake tables
-- Verifies which PostgreSQL permission checks apply to DuckLake tables.
--
-- Current state: pg_duckdb's planner hook sets permInfos = NULL and only
-- checks VIEW permissions, so most DML permission checks are bypassed
-- when queries are routed through DuckDB. What works:
--   - DDL ownership checks (ALTER/DROP require table owner)
--   - VACUUM ownership check
-- What does NOT work (known gaps):
--   - SELECT/INSERT/UPDATE/DELETE table-level permissions
--   - Column-level SELECT restrictions
--   - time_travel() bypasses all table-level checks
-- Setup: create roles with duckdb_group + filesystem access
CREATE USER ducklake_superuser IN ROLE duckdb_group, pg_read_server_files, pg_write_server_files;
CREATE USER ducklake_writer IN ROLE duckdb_group, pg_read_server_files, pg_write_server_files;
CREATE USER ducklake_reader IN ROLE duckdb_group, pg_read_server_files, pg_write_server_files;
CREATE USER ducklake_no_access IN ROLE duckdb_group, pg_read_server_files, pg_write_server_files;
-- Create test table as superuser
CREATE TABLE acl_test (id int, name text, secret text) USING ducklake;
INSERT INTO acl_test VALUES (1, 'Alice', 'pw1'), (2, 'Bob', 'pw2');
-- Grant ALL to ducklake_superuser
GRANT ALL ON TABLE acl_test TO ducklake_superuser;
-- Grant DML to writer
GRANT SELECT, INSERT, UPDATE, DELETE ON TABLE acl_test TO ducklake_writer;
-- Grant SELECT only to reader
GRANT SELECT ON TABLE acl_test TO ducklake_reader;
-- ducklake_no_access gets nothing on the table
-- DuckLake metadata tables: grant DML so DuckDB SPI can write snapshots
GRANT ALL ON ALL TABLES IN SCHEMA ducklake TO ducklake_superuser, ducklake_writer, ducklake_reader, ducklake_no_access;
GRANT ALL ON ALL SEQUENCES IN SCHEMA ducklake TO ducklake_superuser, ducklake_writer, ducklake_reader, ducklake_no_access;
-- ============================================================
-- 1. Full-access role: all DML works
-- ============================================================
SET ROLE ducklake_superuser;
SELECT * FROM acl_test ORDER BY id;
 id | name  | secret 
----+-------+--------
  1 | Alice | pw1
  2 | Bob   | pw2
(2 rows)

INSERT INTO acl_test VALUES (3, 'Carol', 'pw3');
UPDATE acl_test SET name = 'Updated' WHERE id = 3;
DELETE FROM acl_test WHERE id = 3;
RESET ROLE;
-- ============================================================
-- 2. DDL ownership: ALTER/DROP fail for non-owner
-- ============================================================
SET ROLE ducklake_writer;
ALTER TABLE acl_test ADD COLUMN extra int;
ERROR:  must be owner of table acl_test
DROP TABLE acl_test;
ERROR:  must be owner of table acl_test
RESET ROLE;
-- ============================================================
-- 3. VACUUM ownership: non-owner gets WARNING
-- ============================================================
SET ROLE ducklake_writer;
VACUUM acl_test;
WARNING:  permission denied to vacuum "acl_test", skipping it
RESET ROLE;
-- Owner succeeds
VACUUM acl_test;
-- ============================================================
-- 4. Known gap: DML permissions not enforced
--    Reader can INSERT/UPDATE/DELETE (should fail but doesn't)
-- ============================================================
SET ROLE ducklake_reader;
-- SELECT works (expected)
SELECT count(*) FROM acl_test;
 count 
-------
     2
(1 row)

-- These succeed even though reader only has SELECT (known gap)
INSERT INTO acl_test VALUES (10, 'Ghost', 'x');
DELETE FROM acl_test WHERE id = 10;
RESET ROLE;
-- Verify no data leaked from the gap test
SELECT * FROM acl_test ORDER BY id;
 id | name  | secret 
----+-------+--------
  1 | Alice | pw1
  2 | Bob   | pw2
(2 rows)

-- ============================================================
-- 5. Known gap: no-access role can still query (should fail)
-- ============================================================
SET ROLE ducklake_no_access;
SELECT count(*) FROM acl_test;
 count 
-------
     2
(1 row)

RESET ROLE;
-- ============================================================
-- 6. Known gap: column-level privileges not enforced
-- ============================================================
REVOKE ALL ON TABLE acl_test FROM ducklake_reader;
GRANT SELECT (id, name) ON TABLE acl_test TO ducklake_reader;
SET ROLE ducklake_reader;
-- Granted columns work
SELECT id, name FROM acl_test ORDER BY id;
 id | name  
----+-------
  1 | Alice
  2 | Bob
(2 rows)

-- Non-granted column also works (known gap)
SELECT secret FROM acl_test ORDER BY id;
 secret 
--------
 pw1
 pw2
(2 rows)

RESET ROLE;
-- ============================================================
-- 7. Known gap: time_travel bypasses all checks
-- ============================================================
SELECT max(snapshot_id) AS latest_snap FROM ducklake.ducklake_snapshot \gset
REVOKE ALL ON TABLE acl_test FROM ducklake_no_access;
SET ROLE ducklake_no_access;
SELECT count(*) FROM ducklake.time_travel('acl_test', :latest_snap);
 count 
-------
     2
(1 row)

RESET ROLE;
-- ============================================================
-- Cleanup
-- ============================================================
DROP TABLE acl_test;
REVOKE ALL ON ALL TABLES IN SCHEMA ducklake FROM ducklake_superuser, ducklake_writer, ducklake_reader, ducklake_no_access;
REVOKE ALL ON ALL SEQUENCES IN SCHEMA ducklake FROM ducklake_superuser, ducklake_writer, ducklake_reader, ducklake_no_access;
DROP USER ducklake_superuser, ducklake_writer, ducklake_reader, ducklake_no_access;
